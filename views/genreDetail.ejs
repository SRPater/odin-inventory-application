<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <nav>
    <a href="/genres">← Back to All Genres</a> |
    <a href="/genres/<%= genre.id %>/edit">Update</a>
  </nav>

  <h1><%= genre.name %></h1>
  <form
    action="/genres/<%= genre.id %>/delete"
    method="POST"
    onsubmit="return confirm('Are you sure you want to delete this genre?')"
  >
    <button type="submit">Delete</button>
  </form>

  <hr>

  <h3>Games in this Genre (<%= genre.games.length %>)</h3>
  <ul>
    <% if (genre.games.length > 0) { %>
      <% genre.games.forEach(game => { %>
        <li>
          <a href="/games/<%= game.id %>"><%= game.name %></a>
        </li>
      <% }); %>
    <% } else { %>
      <li>No games listed for this genre.</li>
    <% } %>
  </ul>
</body>
</html>