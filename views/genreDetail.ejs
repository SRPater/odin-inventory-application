<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% title %></title>
</head>
<body>
  <nav>
    <a href="/genres">← Back to All Genres</a>
  </nav>

  <h1><%= genre.name %></h1>
  <p><strong>Genre ID:</strong> <%= genre.id %></p>

  <hr>

  <h3>Games in this Genre</h3>
  <ul>
    <% if (genre.games.length > 0 ) { %>
      <% genre.games.forEach(game => { %>
        <li>
          <a href="/games/<%= game.id %>"><%= game.name %></a>
        </li>
      <%> }); %>
    <% } else { %>
      <li>No games listed for this genre.</li>
    <% } %>
  </ul>
</body>
</html>