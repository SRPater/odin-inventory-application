<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>
  <nav>
    <a href="/">Games</a> |
    <a href="/developers">Developers</a>
  </nav>
  <hr>
  <ul>
    <% if (genres.length > 0) { %>
      <% genres.forEach(genre => { %>
        <li>
          <a href="/genres/<%= genre.id %>"><%= genre.name %></a>
        </li>
      <% }); %>
    <% } else { %>
      <li>No genres found.</li>
    <% } %>
  </ul>
</body>
</html>