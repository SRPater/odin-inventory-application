<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <nav>
    <a href="/genres<%= genre ? `/${genre.id}` : '' %>">
      ← Back to <%= genre ? genre.name : 'All Genres' %>
    </a>
  </nav>

  <h1><%= title %></h1>

  <hr>

  <form
    action="/genres/<%= genre ? `${genre.id}/edit` : 'new' %>"
    method="POST"
  >
    <div>
      <label for="name">Genre Name:</label>
      <input
        type="text"
        name="name"
        id="name"
        value="<%= genre ? genre.name : '' %>"
        required
      >
    </div>
    <br>
    <button type="submit">
      <%= genre ? 'Update Genre' : 'Create Genre' %>
    </button>
  </form>
</body>
</html>