<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <nav>
    <a href="/developers">← Back to All Developers</a> |
    <a href="/developers/<%= developer.id %>/edit">Update</a>
  </nav>

  <h1><%= developer.name %></h1>
  <form
    action="/developers/<%= developer.id %>/delete"
    method="POST"
    onsubmit="return confirm('Are you sure you want to delete this developer?')"
  >
    <button type="submit">Delete</button>
  </form>

  <hr>

  <h3>Games by this Developer</h3>
  <ul>
    <% if (developer.games.length > 0) { %>
      <% developer.games.forEach(game => { %>
        <li>
          <a href="/games/<%= game.id %>"><%= game.name %></a>
        </li>
      <% }); %>
    <% } else { %>
      <li>No games listed for this developer.</li>
    <% } %>
  </ul>
</body>
</html>